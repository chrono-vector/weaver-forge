    },
    {
      "value": "bootstrap_complete",
      "class": "nonterminal_sentinel",
      "may_be_terminal_outcome": false
    }
  ],
  "producer_ownership": {
    "rules": [
      "Container owns the build execution outcome after container execution begins.",
      "Host owns only host infrastructure and orchestration facts.",
      "Host must not overwrite a valid container authoritative outcome merely because a later host integrity gate fails.",
      "A later host integrity failure must be represented in a separate host-owned result field.",
      "Missing, empty, duplicate, malformed, or unsupported authoritative outcome must fail closed.",
      "Validator must not infer the authoritative outcome from cargo_started, build_status, artifact fields, or exit codes.",
      "Terminal outcome must be explicitly present exactly once.",
      "Nonterminal sentinels must not be accepted as terminal outcomes.",
      "CARGO_SUCCEEDED_ARTIFACT_PRESENT is only success-capable; it is not itself sufficient for PASS or host exit 0.",
      "Every failure-only outcome is permanently ineligible for PASS."
    ],
    "container_owns": [
      "container_outcome",
      "cargo_started",
      "cargo_exit_code",
      "artifact_present",
      "artifact_identity_complete",
      "static_inspection_complete"
    ],
    "host_owns": [
      "container_exit_code",
      "host_infrastructure_status",
      "host_source_integrity_status",
      "post_build_integrity_status",
      "evidence_completeness_status"
    ],
    "validator_owns": [
      "validator_status",
      "machine_verdict_ceiling"
    ],
    "shared_identity": [
      "schema_version",
      "run_id"
    ],
    "container_outcome_owner": "container",
    "host_may_replace_container_outcome": false,
    "validator_may_infer_container_outcome": false
  },
  "consumer_rules": {
    "missing_empty_duplicate_malformed_unsupported_outcome": "fail_closed",
    "nonterminal_sentinel_as_terminal_outcome": "reject",
    "contradictory_tuple_values": "reject_not_normalize",
    "missing_required_tuple_members": "reject",
    "success_acceptance": "requires_every_declared_success_requirement",
    "no_component_may_overwrite_foreign_owned_field": true
  },
  "authoritative_result_tuple": {
    "description": "Minimum complete machine result tuple. Contradictory values are rejected, not normalized. Missing required members are rejected.",
    "fields": [
      {
        "name": "schema_version",
        "owner": "shared",
        "required_producer": "shared_identity",
        "terminally_required": true,
        "permitted_values": ["1"],
        "success_requirement": "present_and_supported",
        "host_may_recompute": false,
        "validator_may_infer": false
      },
      {
        "name": "run_id",
        "owner": "shared",
        "required_producer": "shared_identity",
        "terminally_required": true,
        "permitted_values": ["nonempty_run_id"],
        "success_requirement": "present_and_consistent_across_evidence",
        "host_may_recompute": false,
        "validator_may_infer": false
      },
      {
        "name": "container_outcome",
        "owner": "container",
        "required_producer": "container",
        "terminally_required": true,
        "permitted_values": [
          "BUILD_NOT_STARTED",
          "CARGO_FAILED",
          "CARGO_SUCCEEDED_ARTIFACT_MISSING",
          "CARGO_SUCCEEDED_ARTIFACT_PRESENT",
          "INFRASTRUCTURE_FAILURE"
        ],
        "success_requirement": "CARGO_SUCCEEDED_ARTIFACT_PRESENT",
        "host_may_recompute": false,
        "validator_may_infer": false
      },
      {
        "name": "container_exit_code",
        "owner": "host",
        "required_producer": "host",
        "terminally_required": true,
        "permitted_values": ["numeric_docker_process_exit"],
        "success_requirement": "0",
        "host_may_recompute": false,
        "validator_may_infer": false
      },
      {
        "name": "cargo_started",
        "owner": "container",
        "required_producer": "container",
        "terminally_required": true,
        "permitted_values": ["YES", "NO"],
        "success_requirement": "YES",
        "host_may_recompute": false,
        "validator_may_infer": false
      },
      {
        "name": "cargo_exit_code",
        "owner": "container",
        "required_producer": "container",
        "terminally_required": true,
        "permitted_values": ["0", "nonzero_numeric", "NOT_APPLICABLE"],
        "success_requirement": "0",
        "host_may_recompute": false,
        "validator_may_infer": false
      },
      {
        "name": "artifact_present",
        "owner": "container",
        "required_producer": "container",
        "terminally_required": true,
        "permitted_values": ["YES", "NO"],
        "success_requirement": "YES",
        "host_may_recompute": false,
        "validator_may_infer": false
      },
      {
        "name": "artifact_identity_complete",
        "owner": "container",
        "required_producer": "container",
        "terminally_required": true,
        "permitted_values": ["YES", "NO", "NOT_APPLICABLE"],
        "success_requirement": "YES",
        "host_may_recompute": false,
        "validator_may_infer": false
      },
      {
        "name": "static_inspection_complete",
        "owner": "container",
        "required_producer": "container",
        "terminally_required": true,
        "permitted_values": ["YES", "NO", "NOT_APPLICABLE"],
        "success_requirement": "YES",
        "host_may_recompute": false,
        "validator_may_infer": false
      },
      {
        "name": "host_infrastructure_status",
        "owner": "host",
        "required_producer": "host",
        "terminally_required": true,
        "permitted_values": ["OK", "FAILED"],
        "success_requirement": "OK",
        "host_may_recompute": false,
        "validator_may_infer": false
      },
      {
        "name": "host_source_integrity_status",
        "owner": "host",
        "required_producer": "host",
        "terminally_required": true,
        "permitted_values": ["OK", "FAILED"],
        "success_requirement": "OK",
        "host_may_recompute": false,
        "validator_may_infer": false
      },
      {
        "name": "post_build_integrity_status",
        "owner": "host",
        "required_producer": "host",
        "terminally_required": true,
        "permitted_values": ["OK", "FAILED"],
        "success_requirement": "OK",
        "host_may_recompute": false,
        "validator_may_infer": false
      },
      {
        "name": "evidence_completeness_status",
        "owner": "host",
        "required_producer": "host",
        "terminally_required": true,
        "permitted_values": ["COMPLETE", "INCOMPLETE", "FAILED"],
        "success_requirement": "COMPLETE",
        "host_may_recompute": false,
        "validator_may_infer": false
      },
      {
        "name": "validator_status",
        "owner": "validator",
        "required_producer": "validator",
        "terminally_required": true,
        "permitted_values": ["PASS", "FAILED"],
        "success_requirement": "PASS",
        "host_may_recompute": false,
        "validator_may_infer": false
      },
      {
        "name": "machine_verdict_ceiling",
        "owner": "validator",
        "required_producer": "validator",
        "terminally_required": true,
        "permitted_values": ["PASS", "PARTIAL", "FAIL", "INDETERMINATE"],
        "success_requirement": "permits_PASS",
        "host_may_recompute": false,
        "validator_may_infer": false
      }
    ]
  },
  "overwrite_rules": {
    "host_may_replace_valid_container_outcome": false,
    "prohibited_replacement_triggers": [
      "source_HEAD_mismatch",
      "source_dirty_tree_detection",
      "post_build_integrity_failure",
      "evidence_completeness_failure",
      "validator_failure"
    ],
    "required_future_representation": {
      "container_outcome": "unchanged",
      "host_owned_fields_on_failure": {
        "host_source_integrity_status": "FAILED",
        "post_build_integrity_status": "FAILED",
        "evidence_completeness_status": "FAILED",
        "validator_status": "FAILED"
      },
      "effect": "Any such failure makes success impossible without altering the container outcome."
    },
    "known_current_violation": {
      "id": "HOST_OVERWRITES_CONTAINER_BUILD_EXIT_CODE",
      "status": "UNRESOLVED_IMPLEMENTATION_VIOLATION",
      "remediation_phase": "3D",
      "description": "Current host script may overwrite container BUILD_EXIT_CODE.txt / outcome after post-Docker source integrity or invalid-outcome handling. Contract prohibits this; implementation remains noncompliant until Phase 3D."
    }
  },
  "inference_rules": {
    "validator_may_infer_container_outcome": false,
    "prohibited_derivation_sources": [
      "cargo_started",
      "build_status",
      "artifact_present",
      "cargo_exit_code",
      "docker_exit_code"
    ],
    "prohibited_replacement": "Replacing a missing outcome with INFRASTRUCTURE_FAILURE merely to make a package structurally valid is prohibited as an outcome inference/normalization.",
    "allowed_on_missing_or_invalid_outcome": [
      "Record a separate host infrastructure failure status.",
      "Retain the original missing/invalid container outcome as missing/invalid.",
      "Success must be impossible."
    ],
    "fail_closed": true,
    "known_current_violation": {
      "id": "VALIDATOR_DETERMINE_OUTCOME_INFERENCE",
      "status": "UNRESOLVED_IMPLEMENTATION_VIOLATION",
      "remediation_phase": "later_validator_slice",
      "description": "validate_witness_evidence.determine_outcome currently infers outcome from cargo_started/build_status when explicit outcome is absent/invalid. Contract prohibits inference; implementation remains noncompliant until a later slice removes it."
    }
  },
  "success_eligibility": {
    "preliminary_success_possible_only_when_all_true": [
      "explicit_terminal_container_outcome_is_CARGO_SUCCEEDED_ARTIFACT_PRESENT",
      "docker_container_exit_code_is_zero",
      "cargo_started_YES",
      "cargo_exit_code_0",
      "artifact_present_YES",
