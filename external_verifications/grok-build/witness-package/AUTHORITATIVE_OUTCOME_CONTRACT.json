      "evidence_completeness_status_COMPLETE",
      "validator_status_PASS",
      "machine_verdict_ceiling_permits_PASS"
    ],
    "single_false_missing_duplicate_malformed_or_sentinel_in_required_success_field_prevents_success": true,
    "rejected_success_field_sentinels": [
      "NOT_REACHED",
      "NOT_STARTED",
      "NOT_APPLICABLE"
    ],
    "CARGO_SUCCEEDED_ARTIFACT_PRESENT_alone_insufficient": true,
    "implementation_status": "contract_only_host_gating_not_yet_implemented"
  },
  "failure_rules": {
    "failure_only_outcomes": [
      "BUILD_NOT_STARTED",
      "CARGO_FAILED",
      "CARGO_SUCCEEDED_ARTIFACT_MISSING",
      "INFRASTRUCTURE_FAILURE"
    ],
    "failure_only_outcomes_permanently_ineligible_for_PASS": true,
    "only_success_capable_outcome": "CARGO_SUCCEEDED_ARTIFACT_PRESENT",
    "missing_invalid_outcome": "fail_closed_with_separate_host_infrastructure_failure_record"
  },
