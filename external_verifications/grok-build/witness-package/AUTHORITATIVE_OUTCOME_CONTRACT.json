{
  "contract_version": "1.0.0-phase3b",
  "contract_status": "CONTRACT_DEFINED_ON_MAIN_IMPLEMENTATION_PENDING",
  "contract_phase": "3B",
  "contract_scope": "Authoritative outcome vocabulary, producer ownership, result tuple, no-inference, and no-overwrite rules. Normative for future rc5 remediation. Does not claim current runtime compliance.",
  "base_commit": "24a329c5fca4f9ee2ec974509ea589ecb402f876",
  "terminal_outcomes": [
    {
      "value": "BUILD_NOT_STARTED",
      "meaning": "Container execution began but cargo was never invoked.",
      "terminal": true,
      "success_capable": false,
      "cargo_started": "NO",
      "cargo_exit_class": "NOT_APPLICABLE",
      "artifact_requirement": "ABSENT",
      "permitted_primary_producer": "container",
      "host_may_replace": false,
      "validator_may_infer": false,
      "tuple_consistency": {
        "cargo_started": "NO",
        "artifact_present": "NO",
        "success_capable": false
      }
    },
    {
      "value": "CARGO_FAILED",
      "meaning": "Cargo started and exited nonzero.",
      "terminal": true,
      "success_capable": false,
      "cargo_started": "YES",
      "cargo_exit_class": "NONZERO",
      "artifact_requirement": "ABSENT_OR_UNUSABLE_PARTIAL_ONLY_IF_EXPLICITLY_DOCUMENTED",
      "permitted_primary_producer": "container",
      "host_may_replace": false,
      "validator_may_infer": false,
      "tuple_consistency": {
        "cargo_started": "YES",
        "cargo_exit_code": "nonzero",
        "artifact_present": "NO_unless_explicitly_documented_unusable_partial",
        "success_capable": false
      }
    },
    {
      "value": "CARGO_SUCCEEDED_ARTIFACT_MISSING",
      "meaning": "Cargo exited 0 but the expected artifact is absent.",
      "terminal": true,
      "success_capable": false,
      "cargo_started": "YES",
      "cargo_exit_class": "ZERO",
      "artifact_requirement": "ABSENT",
      "permitted_primary_producer": "container",
      "host_may_replace": false,
      "validator_may_infer": false,
      "tuple_consistency": {
        "cargo_started": "YES",
        "cargo_exit_code": "0",
        "artifact_present": "NO",
        "success_capable": false
      }
    },
    {
      "value": "CARGO_SUCCEEDED_ARTIFACT_PRESENT",
      "meaning": "Cargo exited 0 and the expected artifact is present. Success-capable only; not itself sufficient for PASS or host exit 0.",
      "terminal": true,
      "success_capable": true,
      "cargo_started": "YES",
      "cargo_exit_class": "ZERO",
      "artifact_requirement": "PRESENT",
      "permitted_primary_producer": "container",
      "host_may_replace": false,
      "validator_may_infer": false,
      "tuple_consistency": {
        "cargo_started": "YES",
        "cargo_exit_code": "0",
        "artifact_present": "YES",
        "success_capable": true,
        "additional_success_gates_required": [
          "artifact_identity_complete",
          "static_inspection_complete",
          "host_infrastructure_status",
          "host_source_integrity_status",
          "post_build_integrity_status",
          "evidence_completeness_status",
          "validator_status",
          "machine_verdict_ceiling"
        ]
      }
    },
    {
      "value": "INFRASTRUCTURE_FAILURE",
      "meaning": "An infrastructure or environment fault prevented a trustworthy build result. Failure owner/stage must be identified. cargo_started may be YES or NO depending on failure timing; container-owned cargo facts remain preserved when cargo already ran.",
      "terminal": true,
      "success_capable": false,
      "cargo_started": "YES_OR_NO",
      "cargo_exit_class": "PRESERVE_CONTAINER_FACTS",
      "artifact_requirement": "CONTEXT_DEPENDENT",
      "permitted_primary_producer": "container_or_host_infrastructure_owner",
      "host_may_replace": false,
      "validator_may_infer": false,
      "tuple_consistency": {
        "success_capable": false,
        "cargo_started": "YES_OR_NO",
        "must_identify_infrastructure_failure_owner_or_stage": true,
        "must_not_impose_universal_cargo_started_NO": true,
        "preserve_container_cargo_facts_when_cargo_already_ran": true
      }
    }
  ],
  "nonterminal_sentinels": [
    {
      "value": "NOT_REACHED",
      "class": "nonterminal_sentinel",
      "may_be_terminal_outcome": false
    },
    {
      "value": "NOT_STARTED",
      "class": "nonterminal_sentinel",
      "may_be_terminal_outcome": false
    },
    {
